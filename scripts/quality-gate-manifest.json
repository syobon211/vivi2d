{
  "schemaVersion": 1,
  "description": "Canonical map from local quality gates to CI workflow coverage. scripts/check-quality-gate-drift.mjs compares this file with scripts/run-quality-gates.mjs and .github/workflows/*.yml.",
  "excludedWorkflows": [
    {
      "path": ".github/workflows/codeql.yml",
      "reason": "CodeQL is a dedicated security-analysis workflow, not a local quality-gate mirror."
    },
    {
      "path": ".github/workflows/perf-monitor.yml",
      "reason": "Performance monitoring is report-only or scheduled and is not part of the blocking quality-gate set."
    },
    {
      "path": ".github/workflows/publish-web-alpha.yml",
      "reason": "Manual protected npm publication workflow; checked by npm run check:web-npm-alpha-release rather than mirrored as a normal quality gate."
    },
    {
      "path": ".github/workflows/github-release-alpha.yml",
      "reason": "Manual protected GitHub Release workflow; checked by npm run check:github-release-alpha rather than mirrored as a normal quality gate."
    },
    {
      "path": ".github/workflows/windows-installer-alpha.yml",
      "reason": "Manual protected Windows installer release workflow; checked by npm run check:windows-installer-alpha rather than mirrored as a normal quality gate."
    }
  ],
