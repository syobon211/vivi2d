{
  "name": "@vivi2d/viewer-api-client",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "vivi2d": {
    "publication": "internal"
  },
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run packages/viewer-api-client/src/__tests__ --root ../.. --config ./vitest.config.ts --no-coverage"
  },
  "license": "Apache-2.0"
}
