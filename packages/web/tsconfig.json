{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationDir": "dist",
    "emitDeclarationOnly": true,
    "strict": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "paths": {
      "@vivi2d/core": ["../core/src/index.ts"],
      "@vivi2d/core/*": ["../core/src/*"],
      "@vivi2d/model": ["../model/src/index.ts"],
      "@vivi2d/model/*": ["../model/src/*"],
      "@vivi2d/runtime": ["../runtime/src/index.ts"],
      "@vivi2d/runtime/*": ["../runtime/src/*"],
      "@vivi2d/renderer-pixi": ["../renderer-pixi/src/index.ts"],
      "@vivi2d/renderer-pixi/*": ["../renderer-pixi/src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["src/__tests__"]
}
