{
  "name": "@vivi2d/viewer",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "vivi2d": {
    "publication": "internal-app"
  },
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on tcp:3000 && cross-env VITE_DEV_SERVER_URL=http://localhost:3000 electron .\"",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:typecheck": "tsc --noEmit -p tsconfig.test.json && tsc --noEmit -p tsconfig.e2e.json",
    "pretest:e2e": "npm run build",
    "test:e2e": "playwright test -c e2e/playwright.config.ts",
    "test:e2e:api": "playwright test -c e2e/playwright.config.ts --project=viewer-api",
    "check": "npm run test:typecheck && npm run test && npm run test:e2e",
    "start": "electron ."
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.34",
    "@vivi2d/core": "^0.1.0",
    "@vivi2d/renderer-pixi": "^0.1.0",
    "pixi.js": "^8.18.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.2.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "wait-on": "^9.0.10"
  }
}
