      "types": "./dist/artifact-policy.d.ts",
      "import": "./dist/artifact-policy.js"
    },
    "./invocation": {
      "types": "./dist/invocation.d.ts",
      "import": "./dist/invocation.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js"
    }
  },
  "sideEffects": false,
  "license": "Apache-2.0"
}
