{
  "name": "@vivi2d/provider-sdk",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "vivi2d": {
    "publication": "internal"
  },
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
