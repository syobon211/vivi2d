{
  "name": "vivi2d",
  "private": true,
  "version": "0.1.0",
  "license": "Apache-2.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on tcp:1420 && cross-env VITE_DEV_SERVER_URL=http://localhost:1420 electron .\"",
    "build": "tsc && vite build",
    "build:packages": "npm run build --workspace @vivi2d/runtime && npm run build --workspace @vivi2d/web && npm run build --workspace @vivi2d/viewer-api-client && npm run build --workspace @vivi2d/provider-sdk",
    "build:e2e": "tsc && cross-env VITE_EXPOSE_E2E=true vite build",
    "start": "electron .",
    "preview": "vite preview",
    "notices:generate": "node scripts/generate-third-party-notices.mjs",
    "notices:check": "node scripts/generate-third-party-notices.mjs --check",
    "sbom:generate": "node scripts/generate-sbom.mjs",
    "check:sbom": "node scripts/generate-sbom.mjs --check",
    "build:fixtures": "node scripts/generate-web-sdk-basic-fixture.mjs",
    "smoke:comfyui:compat": "node scripts/smoke-comfyui-vivi2d-compat.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "node scripts/run-e2e-projects.mjs",
    "test:e2e:smoke": "node scripts/run-e2e-projects.mjs --project=smoke",
    "test:e2e:workflows": "node scripts/run-e2e-projects.mjs --project=workflows",
    "test:e2e:workflow-record": "node scripts/run-e2e-projects.mjs --project=workflows --record",
    "test:e2e:visual": "node scripts/run-e2e-projects.mjs --project=visual",
    "test:e2e:perf": "node scripts/run-e2e-projects.mjs --project=perf",
    "test:e2e:full": "node scripts/run-e2e-projects.mjs --project=full",
    "test:e2e:headed": "node scripts/run-e2e-projects.mjs --headed",
    "test:fuzz:parsers": "vitest run packages/model/src/__tests__/public-profile-fuzz.test.ts packages/core/src/__tests__/vivib-format.fuzz.test.ts src/workers/__tests__/psd-parse.worker.fuzz.test.ts packages/viewer/src/__tests__/viewer-api-parser.fuzz.test.ts electron/__tests__/ipc-contract-fuzz.test.ts --no-coverage && python -m pytest integrations/comfyui/vivi2d_compat_plugin/tests/test_manifest_fuzz.py",
    "test:runtime-wasm:browser": "node scripts/check-runtime-wasm-browser.mjs",
    "bench:runtime-wasm": "vitest bench packages/runtime-wasm/src/__bench__/runtime-wasm-update.bench.ts",
    "check:architecture-boundaries": "node scripts/check-architecture-boundaries.mjs",
    "check:import-cycles": "node scripts/check-import-cycles.mjs",
    "check:workspace-layout": "node scripts/check-workspace-layout.mjs",
    "check:docs-architecture": "node scripts/check-docs-architecture.mjs",
    "check:task-guide-paths": "node scripts/check-task-guide-paths.mjs",
    "check:task-guide-gates": "node scripts/check-task-guide-gates.mjs",
    "check:pr-recipe-gates": "node scripts/check-pr-recipe-gates.mjs",
    "check:troubleshooting-content": "node scripts/check-troubleshooting-content.mjs",
    "check:content-safety-integrity": "node scripts/check-content-safety-integrity.mjs",
    "check:escalation-template": "node scripts/check-escalation-template.mjs",
    "docs:user:check": "node scripts/check-user-docs.mjs",
    "docs:user:check:release": "node scripts/check-user-docs.mjs --release-candidate",
    "docs:user:changed-copy": "node scripts/extract-user-docs-changed-copy.mjs",
    "docs:media:check": "node scripts/check-user-docs-media.mjs",
    "docs:site:build": "node apps/vivi2d-com/scripts/build.mjs",
    "docs:site:check": "node scripts/check-vivi2d-com-site.mjs",
    "check:docs-public-surface": "node scripts/check-docs-public-surface.mjs",
    "check:quality-gate-drift": "node scripts/check-quality-gate-drift.mjs",
    "check:e2e-project-coverage": "node scripts/check-e2e-project-coverage.mjs",
    "check:ipc-contract": "vitest run electron/__tests__/security.test.ts electron/__tests__/file-ipc.test.ts electron/__tests__/comfyui-ipc.test.ts packages/viewer/src/__tests__/electron-security.test.ts",
    "check:ipc-contract-sync": "node scripts/check-ipc-contract-sync.mjs",
    "check:ip-markers": "node scripts/check-ip-markers.mjs",
    "check:ip-product-profile": "node scripts/check-ip-product-profile.mjs",
    "check:packages-types": "tsc --noEmit -p tsconfig.packages.json",
    "check:pack-contents": "node scripts/check-pack-contents.mjs",
    "check:bundle": "node scripts/check-bundle-budget.mjs",
    "check:license-policy": "node scripts/check-license-policy.mjs",
    "check:native-artifact-policy": "node scripts/check-native-artifact-policy.mjs",
    "check:source-comments": "node scripts/check-source-comments.mjs",
    "check:core-model-current-fixtures": "node scripts/check-core-model-current-fixtures.mjs",
    "check:model-fixtures": "vitest run packages/model/src/__tests__ --no-coverage",
    "check:provider-conformance": "vitest run packages/provider-sdk/src/__tests__ --no-coverage",
    "check:provider-sdk-samples": "node scripts/check-provider-sdk-samples.mjs",
    "check:samples-public-surface": "node scripts/check-samples-public-surface.mjs",
    "check:sdk-external-consumer": "node scripts/check-sdk-external-consumer.mjs",
    "check:viewer-types": "npm run test:typecheck --workspace @vivi2d/viewer",
    "check:viewer-test-text": "node scripts/check-viewer-test-text.mjs",
    "check:viewer-tests": "npm run check:viewer-types && npm run check:viewer-test-text && npm run test --workspace @vivi2d/viewer",
    "vendor:viewer-mediapipe-assets": "node scripts/vendor-viewer-mediapipe-assets.mjs",
    "check:viewer-mediapipe-assets": "node scripts/vendor-viewer-mediapipe-assets.mjs --check",
    "check:viewer-api-samples:smoke": "node scripts/check-viewer-api-browser-sample-smoke.mjs",
    "check:viewer-api-samples": "node scripts/check-viewer-api-samples.mjs && npm run check:viewer-api-samples:smoke",
    "check:samples:static": "node scripts/check-web-sdk-basic-static.mjs",
    "check:samples:smoke": "node scripts/check-web-sdk-basic-smoke.mjs",
    "check:samples": "npm run check:samples:static && npm run check:samples:smoke",
    "check:viewer-api-contracts": "node scripts/check-viewer-api-contracts.mjs",
    "check:viewer-api-e2e": "npm run build --workspace @vivi2d/viewer && npx playwright test -c packages/viewer/e2e/playwright.config.ts --project=viewer-api",
    "check:oss-readiness": "node scripts/check-oss-readiness.mjs",
    "check:oss-publication": "node scripts/check-oss-readiness.mjs --public-source-publication",
    "check:web-npm-alpha-release": "node scripts/check-web-npm-alpha-release.mjs",
    "release:web-npm-alpha:publish": "node scripts/publish-web-npm-alpha.mjs",
    "check:github-release-alpha": "node scripts/check-github-release-alpha.mjs",
    "release:github:prepare": "node scripts/prepare-github-release-assets.mjs",
    "release:github:review-packet": "node scripts/generate-github-release-alpha-review-packet.mjs",
    "check:npm-token-hygiene": "node scripts/check-npm-token-hygiene.mjs",
    "check:environment-protection": "node scripts/check-environment-protection.mjs",
    "check:package-boundaries": "node scripts/check-package-boundaries.mjs",
    "check:sdk-unlock:web": "node scripts/check-web-sdk-unlock.mjs",
    "check:publication-history": "node scripts/check-publication-history.mjs",
    "check:secrets": "node scripts/check-secrets.mjs",
    "check:hosted-release-surfaces": "node scripts/check-hosted-release-surfaces.mjs",
    "check:workflow-artifact-safety": "node scripts/check-hosted-release-surfaces.mjs",
    "check:release-surface": "node scripts/check-release-surface.mjs",
    "archive:source-review": "node scripts/create-source-review-archive.mjs",
    "check:source-review-archive": "node scripts/create-source-review-archive.mjs --check",
    "generate:local-motion-marker-catalogs": "node scripts/generate-local-motion-marker-catalogs.mjs",
    "check:local-motion-marker-catalogs": "node scripts/generate-local-motion-marker-catalogs.mjs --check",
    "check:local-motion-private-markers": "node scripts/check-local-motion-private-markers.mjs",
    "check:local-motion-worker-fixtures": "node scripts/check-local-motion-worker-fixtures.mjs",
    "check:clean-room-coverage": "node scripts/check-clean-room-coverage.mjs",
    "check:auto-setup-ip-compliance": "node scripts/check-auto-setup-ip-compliance.mjs",
    "check:runtime-c-abi": "node scripts/check-runtime-c-abi.mjs",
    "check:runtime-c-abi-link": "node scripts/check-runtime-c-abi-link.mjs",
    "check:runtime-native": "npm run check --workspace @vivi2d/runtime-native",
    "check:security-patterns": "node scripts/check-security-patterns.mjs",
    "check:direct-model-mutations": "node scripts/check-direct-model-mutations.mjs",
    "check:ui-module-budget": "node scripts/check-ui-module-budget.mjs",
    "check:quality": "node scripts/run-quality-gates.mjs",
    "check:quality:coverage": "node scripts/run-quality-gates.mjs --coverage",
    "check:quality:e2e-smoke": "node scripts/run-quality-gates.mjs --coverage --e2e-smoke",
    "check:quality:e2e-workflows": "node scripts/run-quality-gates.mjs --e2e-smoke --e2e-workflows",
    "check:quality:e2e-workflow-record": "node scripts/run-quality-gates.mjs --e2e-smoke --e2e-workflow-record",
    "video:focus": "node scripts/focus-e2e-webm.mjs",
    "check:history-secrets": "node scripts/check-history-secrets.mjs",
    "audit:all": "npm audit --audit-level=moderate",
    "audit:prod": "npm audit --omit=dev --audit-level=moderate",
    "i18n:check:english-surface": "node scripts/check-english-locale-surface.mjs",
    "i18n:check": "vitest run src/lib/i18n/__tests__/key-consistency.test.ts --no-coverage",
    "i18n:check:viewer": "vitest run packages/viewer/src/__tests__/i18n.test.ts packages/viewer/src/__tests__/useLocaleToggle.test.tsx --no-coverage",
    "i18n:check:hygiene": "node scripts/check-i18n-hygiene.mjs",
    "i18n:check:layout": "node scripts/check-i18n-layout.mjs",
    "i18n:check:review": "node scripts/check-i18n-review-manifest.mjs",
    "check:i18n-review-manifest": "node scripts/check-i18n-review-manifest.mjs",
    "i18n:check:all": "npm run i18n:check && npm run i18n:check:viewer && npm run i18n:check:hygiene && npm run i18n:check:english-surface && npm run i18n:check:layout && npm run i18n:check:review"
  },
  "overrides": {
    "@xmldom/xmldom": "0.8.13",
    "axios": "1.15.2",
    "ws": "8.21.0"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "ag-psd": "^30.1.1",
    "delaunator": "^5.1.0",
    "immer": "^11.1.4",
    "pixi.js": "^8.18.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "4.4.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@biomejs/biome": "^2.4.10",
    "@cyclonedx/cyclonedx-npm": "^4.2.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.2",
    "axe-core": "^4.11.3",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^41.2.1",
    "happy-dom": "^20.9.0",
    "msw": "^2.13.4",
    "three": "^0.183.2",
    "typescript": "^5.9.3",
    "vite": "^6.4.2",
    "vitest": "^4.1.2",
    "wait-on": "^8.0.5"
  }
}
